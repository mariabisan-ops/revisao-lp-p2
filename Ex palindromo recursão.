#include <stdio.h>
#include <string.h>

int palindromo (char[],int, int);

int main(){
  char palavra [30];
  printf ("Palavra: ");
  fgets (palavra, sizeof (palavra), stdin);
  palavra [strlen(palavra)-1]='\0';
  if (palindromo (palavra,0, strlen(palavra)-1){
    printf ("\nE palindromo");
  }
  else {
    printf ("\nNao e palindromo");
  }
} 

int palindromo (char p[], int inicio, int fim){
  if (inicio>=fim){
    return 1;
  }
  else {
    if (p[inicio]!=p[fim]){
      return 0;
    }
    else{
      palindromo (p, inicio+1, fim-1);
    }
  }
}
