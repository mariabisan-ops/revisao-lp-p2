#include <stdio.h>

void trocaMaior (int*, int*);

int main(){
  int a, b;
  printf ("A: ");
  scanf ("%d", &a);
  printf ("\nB: ");
  scanf ("%d", &b);
  trocaMaior(&a, &b);
  printf ("\nMaior: %d", a);
  printf ("\nMenor: %d", b);
}

void trocaMaior (int *a, int *b){
  int aux;
  if (*a<*b){
    aux = *a;
    *a = *b;
    *b = aux;
  }
}
