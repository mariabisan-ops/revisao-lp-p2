/*
S(5)=5³ + 4³ + 3³ + 2³ + 1³
S(5)= 5³ + S(4)
*/

#include <stdio.h>

int somaCubos (int);

int main (){
    int n;
    printf ("digite o valor: ");
    scanf ("%d", &n);
    printf ("soma dos %d primeiros cubos: %d", n, somaCubos(n));
}

int somaCubos (int n){
    if (n==1){
        return 1;
    }    
    return somaCubos (n-1) + (n*n*n);
}
