/*
inverte string
*/

#include <stdio.h>
#include <string.h>

void inverteString (char []);

int main(){
  char str[30];
  printf ("Digite a palavra: ");
  fgets (str, sizeof (str), stdin);
  str [strlen(str) -1] = '\0';

  inverteString (str);
  printf ("\n%s", str);
}

void inverteString (char str[]){
  char aux;
  for (int i=0; i<strlen(str); i++){
    aux = str[i];
    str[i] = str[strlen(str) -1 -i];
    str[strlen(str) -1 -i] = aux;
  }
}
