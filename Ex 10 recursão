#include <stdio.h>

void paresDecrescente (int);

int main (){
    int n;
    printf ("digite o valor: ");
    scanf ("%d", &n);
    printf ("ordem dos pare de %d até 0: ", n);
    paresDecrescente (n);
}

void paresDecrescente (int n){
    if (n==0){
        printf ("0 ");
    }
    else {
        if (n%2==0){
            printf ("%d ", n);
        }
        paresDecrescente (n-1);
    }
}
