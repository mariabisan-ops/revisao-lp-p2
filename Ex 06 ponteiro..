#include <stdio.h>

int somaDobro (int*, int*);

int main(){
  int x, y;
  printf ("X: ");
  scanf ("%d", &x);
  printf ("\nY: ");
  scanf ("%d", &y);
  printf ("\nSoma dos dobros de %d e %d: %d", x, y, somaDobro (&x,&y));
}

int somaDobro (int *a, int *b){
  *a = (*a)*2;
  *b = (*b)*2;
  return *a + *b;
}
