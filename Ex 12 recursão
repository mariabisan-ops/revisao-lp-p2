int menor (int [], int);

int main (){
    int v[10];
    printf ("preencha o vetor: ");
    for (int i=0; i<10; i++){
        scanf ("%d", &v[i]);
    }
    printf ("menor elemento: %d", menor (v, 10));
}

int menor (int v[], int n){
    if (n==1){
        return v[0];
    }
    int m = menor (v+1, m-1);
    if (v[n-1]< m){
        return v[n-1];
    }
    return m;
}
