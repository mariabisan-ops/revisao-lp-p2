#include <stdio.h>

int sequencia (int);

int main (){
    int n;
    printf ("Digite o valor: ");
    scanf ("%d", &n);
    printf ("\n%d-ésimo termo: %d",n,sequencia(n));
}

int sequencia (int n){
    if (n==1){
        return 1;
    }
    if (n==2){
        return 2;
    }
    return (2*sequencia (n-1)) + (3*sequencia(n-2));
}
