#include <stdio.h>

void trocaValor (int, int);

int main(){
  int x, y;
  printf ("X: ");
  scanf ("%d", &x);
  printf ("Y: ");
  scanf ("%d", &y);
  printf ("Valores iniciais:");
  printf ("\n%d", x);
  printf ("\n%d", y);
  trocaValor (&x,&y);
  printf ("Novos valores: ");
  printf ("\n%d", x);
  printf ("\n%d", y);  
}

void trocaValor (int *a, int *b){
  int aux;
  aux = *a;
  *a = *b;
  *b = aux; 
}
