/*
conta caracteres
*/

#include <stdio.h>
#include <string.h>

int contaCaracteres (char []);

int main (){
  char nome [30];
  printf ("Nome: ");
  fgets (nome, sizeof (nome), stdin);
  nome [strlen (nome) - 1] = '\0';
  printf ("\nNumero de caracteres: %d", contaCaracteres (nome);
}

int contaCaracteres (char str[]){
  int cont = 0;
  while (str[cont]!='\0'){
    cont ++;
  }
  return cont;
}
