/*
alocação dinâmica struct
*/

#include <stdio.h>
#include <string.h>

typedef struct {
    char nome [30];
    int RA;
    float notas[3];
    int frequencia;
}Aluno;

int main(){
    Aluno *a;
    
    a = (Aluno*) malloc (sizeof (Aluno));
    
    printf ("\nNome: ");
    fgets (a->nome, sizeof (a->nome), stdin);
    a->nome [strlen(a->nome)-1] = '\0';
    printf ("\nRA: ");
    scanf ("%d", &a->Ra);
    for (int i=0; i<3; i++){
        printf ("\nNota %d: ", i+1);
        scanf ("%f", &a->nota[i]);
    }
    printf ("\nFrequencia: ");
    scanf ("%d", &a->frequencia);
}
