#include <stdio.h>

int ordenaValores(int*,int*,int*);

int main(){
    int n1, n2, n3;

    printf("N1: ");
    scanf("%d",&n1);
    printf("N2: ");
    scanf("%d",&n2);
    printf("N3: ");
    scanf("%d",&n3);

    if(ordenaValores(&n1,&n2,&n3))
        printf("Valores iguais.");
    else
        printf("Valores diferentes");
    printf("\nN1: %d",n1);
    printf("\nN2: %d",n2);
    printf("\nN3: %d",n3);
}

int ordenaValores(int *n1,int *n2,int *n3){
    int aux;
    if(*n1==*n2 && *n1==*n3)
        return 1;
    if(*n1<*n2 && *n1<*n3){
        if(*n2<*n3)
            return 0;
        else{
            aux = *n2;
            *n2 = *n3;
            *n3 = aux;
            return 0;
        }
    }
    if(*n2<*n1 && *n2<*n3){
        aux = *n2;
        *n2 = *n1;
        *n1 = aux;
        if(*n2<*n3)
            return 0;
        else{
            aux = *n2;
            *n2 = *n3;
            *n3 = aux;
            return 0;
        } 
    }
    if(*n3<*n1 && *n3<*n2){
        aux = *n3;
        *n3 = *n1;
        *n1 = aux;
        if(*n2<*n3)
            return 0;
        else{
            aux = *n2;
            *n2 = *n3;
            *n3 = aux;
            return 0;
        } 
    }
}
