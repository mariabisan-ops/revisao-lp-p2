int buscaAluno (Aluno t[], int n, int RA){
  for (int i=0; i<n; i++){
    if (RA==t[i].RA){
      return i;
    }
  }
  return -1;
}

void insereAluno (Aluno t[], int n, int RA){
  t[n].RA = RA;
  dadosAluno(t, n);
}

void dadosAluno (Aluno t[], int pos){
  printf ("\nNome: ");
  getchar ();
  fgets (t[pos].nome, sizeof (t[pos].nome), stdin);
  t[pos].nome [strlen (t[pos].nome) - 1] = '\0';
  for (int i=0; i<3; i++){
    printf ("\nNota %d", i+1);  
    scanf ("%.2f", &t[pos].nota[i]);
  }
  printf ("\nFrequência: ");
  scanf ("%d", &t[pos].frequencia);
}

void imprimeAluno (Aluno t[],int n, int pos){
  printf ("\nDados:");
  printf ("\nRA: %d", t[pos].RA);
  printf ("\nNome: %s", t[pos].nome");
  for (int i=0; i<3; i++){
    printf ("\nNota %d: %.2f", i+1, t[pos].nota[i];
  }
  printf ("\nFrequencia: %d", t[pos].frequencia);
}

void removeAluno (Aluno t[], int pos){
  for (int i=pos; i<n; i++{
    t[i] = t[i+1];
  }
  printf ("\nAluno removido");
}

void imprimeTurma (Aluno [], int n){

  for (int i =0; i<n;i++){
    imprimeAluno (t, i);
  }
}

float calculaMediaAluno (Aluno t[], pos){
  float soma = 0;
  for (int i=0; i<3; i++){
    soma = soma + t[pos].nota[i];
  }
  return soma/3;
}

float calculaMediaTurma (Aluno t[], int n){
  float soma =0;
  for (int i=0; int <n; i++){
    soma = soma + calculaMediaAluno (t, i);
  }
  return soma/n;
}

int maiorMedia (Aluno t[], int n){
  float maior = calculaMediaAluno (t, 0);
  pos = 0;
  for (int i=0; i<n; i++){
    if (calculaMediaTurma (t, i) > maior){
      maior = calculaMediaTurma (t, i);
      pos = i;
    }
  }
  return pos;
}

