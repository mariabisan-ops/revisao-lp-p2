/*
sequencia fibonacci : 0,1,1,2,3,5...
*/

#include <stdio.h>

int main (){
    int n;
    printf ("digite qual termo será calculado: ");
    scanf ("%d", &n);
    printf ("%d-ésimo termo da sequência: %d", n, fibonacci (n));
}

int fibonacci (int n){
    if (n==1){
        return 0;
    }
    if (n==2){
        return 1;
    }
    return fibonacci (n-1) + fibonacci (n-2);
}
