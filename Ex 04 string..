/*
busca nome 
*/

#include <stdio.h>
#include <string.h>

int main(){
  char nome[5][30], buscaNome[30];
  int cont =0;
  for (int i=0; i<5; i++){
    printf("\nNome %d: ", i+1);
    fgets (nome[i], sizeof (nome[i]), stdin);
    nome[i][strlen(nome[i])-1)='\0';
  }
  printf ("\nDigite o nome a ser buscado: ");
  fgets (buscaNome, sizeof (buscaNome), stdin);
  buscaNome [strlen(buscaNome)-1]='\0';

  for (int i=0; i<5; i++){
    if (strcmp (nome[i], buscaNome==0){
      cont++;
      printf ("\nNome encontrado");
      break;
    }
  }
  if (cont==0){
    printf ("\nNome nao encontrado");
  }
}
