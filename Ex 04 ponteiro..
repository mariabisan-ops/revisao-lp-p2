#include <stdio.h>

void trocaValores (int*, int*);

int main(){
  int a, b;
  printf ("A: ");
  scanf ("%d", &a);
  printf ("B: ");
  scanf ("%d", &b);
  trocaValores (&a, &b);
  printf ("Após troca: ");
  printf ("\nA: %d", a);
  printf ("\nB: %d", b);
}

void trocaValores (int *a, int*b){
  int aux;
  aux = *a;
  *a = *b;
  *b = *a;
}
