/*
S(4) = 1^3 + 2^3 + 3^3 + 4^3 = S(3) + 4^3;
*/

#include <stdio.h>

int somaCubos (int);

int main(){
  int n;
  printf ("Digite o valor: ");
  scanf ("%d", &n);
  printf ("soma dos %d primeiros cubos: %d", n, somaCubos (n));
}

int somaCubos (int n){
  if (n==1){
    return 1;
  }
  return somaCubos (n-1) + (n*n*n);
}
