/*
conta caracteres
*/

#include <stdio.h>
#include <string.h>

int contaCaracteres (char[]);

int main(){
  char palavra [30];
  printf ("Palavra: ");
  fgets (palavra, sizeof (palavra), stdin);
  palavra [contaCaracteres (palavra) - 1)= '\0';
  printf ("\nNumero de caracteres: %d ", contaCaracteres (palavra));
}

int contaCaracteres (char p[]){
  int cont =0;
  while (p[cont]!='\0'){
    cont++;
  }
  return cont;
}
