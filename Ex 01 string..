/*
conta caracteres
*/

#include <stdio.h>
#include <string.h>

int contaCaracteres (char[]);

int main(){
  char palavra[30];
  printf ("Palavra: ");
  fgets (palavra, sizeof(palavra), stdin);
  palavra [contaCaracteres(palavra)-1] = '\0';
  printf ("%d caracteres", contaCaracteres (palavra));
}

int contaCaracteres (char t[]){
  int cont=0;
  while (t[cont]!='\0'){
    cont++;
  }
  return cont;
}
