/*
S(5) = 1+2+3+4+5 = S(4) + 5;
S(4) = S(3) + 4;
*/

#include <stdio.h>

int somaN (int);

int main (){
  int n;
  printf ("digite o valor: ");
  scanf ("%d", &n);
  printf ("soma dos elementos de 1 a %d: %d", n, somaN(n));
}

int somaN (int n){
  if (n==1){
    return 1;
  }
  return somaN(n - 1) + n;
}
