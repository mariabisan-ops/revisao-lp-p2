/*
alocação dinamica vetores
*/
#include <stdio.h>

int main (){
    int *v;
    int n;
    
    v = (int*) malloc(n*sizeof(int));
    
    printf ("N: ");
    scanf ("%d", &n);
    for (int i =0; i<n; i++){
        printf ("\nV[%d]", i+1);
        scanf ("%d", &v[i]);
    }
    
    printf ("\nVetor: ");
    for (int i=0; i<n; i++){
        printf ("%d ", v[i]);
    }
    
    free (v);
}
