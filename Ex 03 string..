#include <stdio.h>
#include <string.h>

int palindromo (char[]);

int main (){
  char palavra [30];
  printf ("Palavra: ");
  fgets (palavra, sizeof (palavra), stdin);
  palavra [strlen(palavra) -1] ='\0';
  if (palindromo (palavra)){
    printf ("\nE palindromo");
  }
  else {
    printf ("\nNao e palindromo");
  }
}

int palindromo (char p[]){
  for (int i=0; i<strlen(p); i++){
    if (p[i]!=p[strlen(p)-1-i){
      return 0;
    }
  }
  return 1;
}
