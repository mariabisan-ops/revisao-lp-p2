#include <stdio.h>

void imprimeVetor (int [], int);

int main (){
    int v[10];
    printf ("Preencha o vetor: ");
    for (int i=0; i<10; i++){
        printf ("\nv[%d]: ", i+1);
        scanf ("%d", &v[i]);
    }
    printf ("\nVetor: \n");
    imprimeVetor (v, 10);
}

void imprimeVetor (int v[], int n){
    if (n==1){
        printf ("%d ", v[0]);
    }
    else{
        imprimeVetor (v, n-1);
        printf ("%d ", v[n-1]);
    }
}
