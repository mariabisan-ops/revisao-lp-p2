/*
Declarar e preencher uma string.
Declarar um ponteiro para caractere.
Alocar dinamicamente uma string com o mesmo número de caracteres da string declarada estaticamente.
Usando a função strcpy, copiar a string declarada estaticamente na string declarada dinamicamente.
Imprimir as duas strings e seus endereços.
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(){
  char palavra [30] = 'mensagem';
  char *t;

  t = (char*) malloc ((strlen(palavra)+1 * sizeof (char));

  strcpy (t, palavra);

  printf ("\n%s", palavra);
  printf ("\n%p", palavra);
  printf ("\n%s", t);
  printf ("\n%p", t);
}
